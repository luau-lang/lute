# =============================================================================
# zlib
# =============================================================================

cxx_library(
    name = "zlib",
    srcs = [
        "zlib/adler32.c",
        "zlib/compress.c",
        "zlib/crc32.c",
        "zlib/deflate.c",
        "zlib/gzclose.c",
        "zlib/gzlib.c",
        "zlib/gzread.c",
        "zlib/gzwrite.c",
        "zlib/infback.c",
        "zlib/inffast.c",
        "zlib/inflate.c",
        "zlib/inftrees.c",
        "zlib/trees.c",
        "zlib/uncompr.c",
        "zlib/zutil.c",
    ],
    exported_headers = {
        "zconf.h": "zlib/zconf.h",
        "zlib.h": "zlib/zlib.h",
    },
    headers = subdir_glob([("zlib", "*.h")]),
    header_namespace = "",
    exported_preprocessor_flags = ["-DZLIB_STATIC"],
    compiler_flags = [
        "-Wno-implicit-fallthrough",
        "-Wno-implicit-function-declaration",
        "-Wno-deprecated-non-prototype",
    ],
    preprocessor_flags = ["-DHAVE_UNISTD_H"],
    preferred_linkage = "static",
    default_target_platform = "//platforms:default",
    visibility = ["PUBLIC"],
)

# =============================================================================
# libuv
# =============================================================================

_libuv_common_sources = glob(["libuv/src/*.c"])

_libuv_unix_sources = [
    "libuv/src/unix/async.c",
    "libuv/src/unix/core.c",
    "libuv/src/unix/dl.c",
    "libuv/src/unix/fs.c",
    "libuv/src/unix/getaddrinfo.c",
    "libuv/src/unix/getnameinfo.c",
    "libuv/src/unix/loop-watcher.c",
    "libuv/src/unix/loop.c",
    "libuv/src/unix/pipe.c",
    "libuv/src/unix/poll.c",
    "libuv/src/unix/process.c",
    "libuv/src/unix/random-devurandom.c",
    "libuv/src/unix/signal.c",
    "libuv/src/unix/stream.c",
    "libuv/src/unix/tcp.c",
    "libuv/src/unix/thread.c",
    "libuv/src/unix/tty.c",
    "libuv/src/unix/udp.c",
]

_libuv_macos_sources = _libuv_unix_sources + [
    "libuv/src/unix/proctitle.c",
    "libuv/src/unix/bsd-ifaddrs.c",
    "libuv/src/unix/kqueue.c",
    "libuv/src/unix/random-getentropy.c",
    "libuv/src/unix/darwin-proctitle.c",
    "libuv/src/unix/darwin.c",
    "libuv/src/unix/fsevents.c",
]

_libuv_linux_sources = _libuv_unix_sources + [
    "libuv/src/unix/proctitle.c",
    "libuv/src/unix/linux.c",
    "libuv/src/unix/procfs-exepath.c",
    "libuv/src/unix/random-getrandom.c",
    "libuv/src/unix/random-sysctl-linux.c",
]

_libuv_platform_sources = _libuv_macos_sources if host_info().os.is_macos else _libuv_linux_sources

cxx_library(
    name = "libuv",
    srcs = _libuv_common_sources + _libuv_platform_sources,
    exported_headers = subdir_glob([
        ("libuv/include", "uv.h"),
        ("libuv/include", "uv/*.h"),
    ]),
    headers = subdir_glob([
        ("libuv/src", "*.h"),
        ("libuv/src/unix", "**/*.h"),
    ]),
    header_namespace = "",
    preprocessor_flags = [
        "-D_FILE_OFFSET_BITS=64",
        "-D_LARGEFILE_SOURCE",
    ] + ([
        "-D_DARWIN_UNLIMITED_SELECT=1",
        "-D_DARWIN_USE_64_BIT_INODE=1",
    ] if host_info().os.is_macos else [
        "-D_GNU_SOURCE",
        "-D_POSIX_C_SOURCE=200112",
    ]),
    compiler_flags = [
        "-std=gnu90",
        "-fvisibility=hidden",
        "-Wstrict-prototypes",
        "-Wextra",
        "-Wno-unused-parameter",
        "-fno-strict-aliasing",
        "-Iextern/libuv/include",
        "-Iextern/libuv/src",
    ],
    preferred_linkage = "static",
    default_target_platform = "//platforms:default",
    visibility = ["PUBLIC"],
)

# =============================================================================
# libsodium
# =============================================================================

_sodium_excluded_x86_patterns = [
    "libsodium/src/libsodium/**/*aesni*",
    "libsodium/src/libsodium/**/*avx*",
    "libsodium/src/libsodium/**/*ssse3*",
    "libsodium/src/libsodium/**/*sse2*",
    "libsodium/src/libsodium/**/*sse41*",
    "libsodium/src/libsodium/**/*xmm*",
    "libsodium/src/libsodium/**/*sandy2x*",
    "libsodium/src/libsodium/**/*dolbeau*",
]

cxx_library(
    name = "sodium",
    srcs = glob(
        ["libsodium/src/libsodium/**/*.c"],
        exclude = _sodium_excluded_x86_patterns + ["libsodium/src/libsodium/**/*.S"],
    ),
    exported_headers = subdir_glob([
        ("libsodium/src/libsodium/include", "*.h"),
        ("libsodium/src/libsodium/include", "sodium/*.h"),
    ]),
    headers = subdir_glob([
        ("libsodium/src/libsodium/include/sodium", "**/*.h"),
        ("libsodium/src/libsodium/crypto_core/ed25519/ref10", "**/*.h"),
        ("libsodium/src/libsodium/crypto_scalarmult/curve25519/ref10", "*.h"),
        ("libsodium/src/libsodium/crypto_scalarmult/curve25519", "*.h"),
        ("libsodium/src/libsodium/crypto_stream/chacha20/ref", "*.h"),
        ("libsodium/src/libsodium/crypto_stream/salsa20/ref", "*.h"),
        ("libsodium/src/libsodium/crypto_onetimeauth/poly1305/donna", "*.h"),
        ("libsodium/src/libsodium/crypto_onetimeauth/poly1305", "*.h"),
        ("libsodium/src/libsodium/crypto_generichash/blake2b/ref", "*.h"),
        ("libsodium/src/libsodium/crypto_pwhash/argon2", "*.h"),
        ("libsodium/src/libsodium/crypto_shorthash/siphash24/ref", "*.h"),
    ]),
    header_namespace = "",
    exported_preprocessor_flags = ["-DSODIUM_STATIC", "-DSODIUM_EXPORT="],
    preprocessor_flags = [
        "-DCONFIGURED",
        "-DDEV_MODE",
        "-D_GNU_SOURCE",
        "-DHAVE_ATOMIC_OPS",
        "-DNATIVE_LITTLE_ENDIAN",
        "-DHAVE_C11_MEMORY_FENCES",
        "-DHAVE_GCC_MEMORY_FENCES",
        "-DHAVE_INLINE_ASM",
        "-DASM_HIDE_SYMBOL=.private_extern",
        "-DTLS=_Thread_local",
        "-DHAVE_CATCHABLE_ABRT=1",
        "-DHAVE_CATCHABLE_SEGV=1",
        "-DHAVE_ARMCRYPTO",
        "-DHAVE_PTHREAD",
        "-DHAVE_MMAP",
        "-DHAVE_MLOCK",
        "-DHAVE_MADVISE",
        "-DHAVE_MPROTECT",
        "-DHAVE_POSIX_MEMALIGN",
        "-DHAVE_NANOSLEEP",
        "-DHAVE_GETPID",
        "-DHAVE_CLOCK_GETTIME",
        "-DHAVE_SYSCONF",
        "-DHAVE_SYS_MMAN_H",
        "-DHAVE_SYS_RANDOM_H",
        "-DHAVE_SYS_PARAM_H",
        "-DHAVE_WEAK_SYMBOLS",
        "-DHAVE_MEMSET_S",
        "-DHAVE_RAISE",
    ],
    compiler_flags = [
        "-fno-strict-aliasing",
        "-fwrapv",
        "-flax-vector-conversions",
        "-Wno-unused-function",
        "-Wno-unknown-pragmas",
        "-Ilibsodium/src/libsodium/include/sodium",
    ],
    preferred_linkage = "static",
    default_target_platform = "//platforms:default",
    visibility = ["PUBLIC"],
)

# =============================================================================
# BoringSSL
# =============================================================================

_bcm_asm_macos_arm64 = ["boringssl/" + f for f in bcm_sources_asm if "apple" in f and ("armv8" in f or "aarch64" in f)]
_crypto_asm_macos_arm64 = ["boringssl/" + f for f in crypto_sources_asm if "apple" in f and ("armv8" in f or "aarch64" in f)]
_bcm_asm_linux_x86_64 = ["boringssl/" + f for f in bcm_sources_asm if "linux" in f and "x86_64" in f]
_crypto_asm_linux_x86_64 = ["boringssl/" + f for f in crypto_sources_asm if "linux" in f and "x86_64" in f]
_bcm_asm_linux_arm64 = ["boringssl/" + f for f in bcm_sources_asm if "linux" in f and ("armv8" in f or "aarch64" in f)]
_crypto_asm_linux_arm64 = ["boringssl/" + f for f in crypto_sources_asm if "linux" in f and ("armv8" in f or "aarch64" in f)]
_bcm_srcs = ["boringssl/" + f for f in bcm_sources]
_crypto_srcs = ["boringssl/" + f for f in crypto_sources]
_ssl_srcs = ["boringssl/" + f for f in ssl_sources]

_boringssl_asm = _bcm_asm_macos_arm64 + _crypto_asm_macos_arm64 if host_info().os.is_macos else (
    _bcm_asm_linux_x86_64 + _crypto_asm_linux_x86_64 if host_info().arch.is_x86_64 else
    _bcm_asm_linux_arm64 + _crypto_asm_linux_arm64
)

cxx_library(
    name = "crypto",
    srcs = _bcm_srcs + _crypto_srcs + _boringssl_asm,
    exported_headers = subdir_glob([("boringssl/include", "openssl/*.h")]),
    headers = subdir_glob([
        ("boringssl/crypto", "**/*.h"),
        ("boringssl/crypto", "**/*.h.inc"),
        ("boringssl/crypto", "**/*.cc.inc"),
        ("boringssl/gen/bcm", "**/*.h"),
        ("boringssl/gen/crypto", "**/*.h"),
        ("boringssl/include", "**/*.h"),
    ]),
    header_namespace = "",
    preprocessor_flags = [
        "-DBORINGSSL_IMPLEMENTATION",
        "-DBORINGSSL_NO_STATIC_INITIALIZER",
    ],
    compiler_flags = [
        "-std=c++17",
        "-fvisibility=hidden",
        "-Wno-unused-parameter",
        "-Iextern/boringssl/include",
    ],
    preferred_linkage = "static",
    default_target_platform = "//platforms:default",
    visibility = ["PUBLIC"],
)

cxx_library(
    name = "ssl",
    srcs = _ssl_srcs,
    exported_headers = subdir_glob([("boringssl/include", "openssl/*.h")]),
    headers = subdir_glob([
        ("boringssl/ssl", "**/*.h"),
        ("boringssl/include", "**/*.h"),
    ]),
    header_namespace = "",
    preprocessor_flags = ["-DBORINGSSL_IMPLEMENTATION"],
    compiler_flags = [
        "-std=c++17",
        "-fvisibility=hidden",
        "-Wno-unused-parameter",
        "-Iextern/boringssl/include",
    ],
    deps = [":crypto"],
    preferred_linkage = "static",
    default_target_platform = "//platforms:default",
    visibility = ["PUBLIC"],
)

# =============================================================================
# curl
# =============================================================================

genrule(
    name = "curl_config",
    srcs = ["curl_config.h"],
    cmd = "cp $SRCS $OUT",
    out = "curl_config.h",
    default_target_platform = "//platforms:default",
)

cxx_library(
    name = "curl",
    srcs = glob(["curl/lib/**/*.c"], exclude = ["curl/lib/dllmain.c", "curl/lib/vssh/*.c"]),
    exported_headers = subdir_glob([("curl/include", "curl/*.h")]),
    headers = subdir_glob([
        ("curl/lib", "**/*.h"),
        ("curl/lib", "**/*.c"),
    ]) | {"curl_config.h": ":curl_config"},
    header_namespace = "",
    exported_preprocessor_flags = ["-DCURL_STATICLIB"],
    preprocessor_flags = [
        "-DBUILDING_LIBCURL",
        "-DHAVE_CONFIG_H",
        "-DCURL_STATICLIB",
        "-Iextern/curl/lib",
    ],
    compiler_flags = [
        "-Wno-unused-parameter",
        "-Wno-deprecated-declarations",
        "-Wno-unused-variable",
    ],
    deps = [":ssl", ":crypto", ":zlib"],
    preferred_linkage = "static",
    default_target_platform = "//platforms:default",
    visibility = ["PUBLIC"],
)

