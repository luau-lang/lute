        "-Wno-unused-parameter",
        "-Wno-sign-compare",
        "-Iextern/uSockets/src",
    ],
    lang_compiler_flags = {
        "c": ["-std=c11"],
        "cxx": ["-std=c++17"],
    },
    deps = [":ssl", ":crypto", ":libuv"],
    preferred_linkage = "static",
    default_target_platform = "//platforms:default",
    visibility = ["PUBLIC"],
)

